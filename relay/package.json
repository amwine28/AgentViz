{
  "name": "agentviz-relay",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "replay": "ts-node --transpile-only src/replay-claude-code.ts",
    "test": "jest"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "globals": {
      "ts-jest": {
        "tsconfig": {
          "target": "ES2022",
          "module": "CommonJS",
          "esModuleInterop": true,
          "strict": true
        }
      }
    }
  }
}
